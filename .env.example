# Satellite Tracking System — environment variable template.
# Copy to .env and fill in real values. Never commit .env to git.

# CelesTrak GP API base URL (no trailing slash)
CELESTRAK_BASE_URL=https://celestrak.org/NORAD/elements/gp.php

# Default satellite group to fetch (e.g. active, starlink, stations)
DEFAULT_GROUP=active

# Directory for caching downloaded TLE files
# Local dev: TLE_CACHE_DIR=.tle_cache
# Docker:    TLE_CACHE_DIR=/app/data/tle_cache  (docker-compose overrides this)
TLE_CACHE_DIR=.tle_cache

# How many hours a cached TLE file remains valid before re-download
TLE_MAX_AGE_HOURS=2

# SQLAlchemy database URL (SQLite file path or connection string)
# Local dev: DATABASE_URL=sqlite:///./satellite_tracking.db
# Docker:    DATABASE_URL=sqlite:////app/data/satellite_tracking.db  (docker-compose overrides this)
DATABASE_URL=sqlite:///./satellite_tracking.db

# Conjunction screening window in hours (recommended: 24–72)
SCREEN_WINDOW_HOURS=48

# Propagation step size in seconds during screening (recommended: 30–60)
SCREEN_STEP_SECONDS=60

# Coarse spatial radius in km for cKDTree neighbour search (recommended: 10–20)
COARSE_RADIUS_KM=15

# Miss-distance threshold in km — events below this are flagged as at-risk
RISK_THRESHOLD_KM=5

# Cesium ion access token (optional — only needed for Cesium ion imagery)
CESIUM_ION_TOKEN=your_cesium_ion_token_here

# CORS — JSON array of allowed frontend origins
# Local dev:  CORS_ORIGINS=["http://localhost:5173"]
# Render/Fly: CORS_ORIGINS=["https://your-app.onrender.com"]
CORS_ORIGINS=["http://localhost:5173"]

# Directory to serve as /static (relative paths are resolved from the project root)
STATIC_DIR=frontend
